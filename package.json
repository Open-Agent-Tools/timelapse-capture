{
  "name": "timelapse-capture",
  "version": "0.1.0",
  "description": "Fire-and-forget visual timelapse capture for long-running app review.",
  "bin": {
    "timelapse-capture": "./src/cli/index.js"
  },
  "scripts": {
    "start": "node ./src/cli/index.js",
    "check": "node --check ./src/cli/index.js && node --check ./src/cli/parser.js && node --check ./src/cli/render.js && node --check ./src/cli/doctor.js",
    "test": "node --test test/*.test.js",
    "ci": "npm run check && npm test"
  },
  "dependencies": {
    "playwright": "^1.59.1"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
