{
  "name": "timelapse-capture",
  "version": "0.4.0",
  "description": "Fire-and-forget visual timelapse capture for long-running app review.",
  "bin": {
    "timelapse-capture": "src/timelapse-capture.mjs"
  },
  "scripts": {
    "postinstall": "node ./scripts/postinstall.mjs",
    "start": "node ./src/timelapse-capture.mjs",
    "check": "node --check ./src/timelapse-capture.mjs && node --check ./src/doctor.mjs && node --check ./src/binaries.mjs && node --check ./scripts/postinstall.mjs",
    "check:local": "bash ./scripts/local-check.sh",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "node --test \"test/**/*.test.js\" \"test/**/*.test.mjs\"",
    "ci": "npm run check && npm run format:check && npm run typecheck && npm test"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "playwright": "^1.59.1"
  },
  "files": [
    "src/",
    "scripts/postinstall.mjs",
    "scripts/install-windows.ps1"
  ],
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Open-Agent-Tools/timelapse-capture.git"
  },
  "homepage": "https://github.com/Open-Agent-Tools/timelapse-capture#readme",
  "bugs": {
    "url": "https://github.com/Open-Agent-Tools/timelapse-capture/issues"
  },
  "keywords": [
    "timelapse",
    "screenshot",
    "capture",
    "playwright",
    "visual-testing",
    "monitoring",
    "cli"
  ],
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
